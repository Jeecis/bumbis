# Reverse-proxy the matchmaking API. Paste this `location` block INSIDE the
# existing `server { ... }` block that serves the Bumbis static site, next to
# `location / { ... }`. Then: sudo nginx -t && sudo systemctl reload nginx
#
# The SSE-specific lines (proxy_buffering off, HTTP/1.1, long read timeout) are
# required — without them the live check-in stream stalls or drops.

location /api/ {
    proxy_pass http://127.0.0.1:8787;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    # Server-Sent Events: stream events through immediately, never buffer/cache.
    proxy_set_header Connection '';
    proxy_buffering off;
    proxy_cache off;
    proxy_read_timeout 3600s;
}
